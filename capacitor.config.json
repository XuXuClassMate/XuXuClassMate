{
  "appId": "com.xuxuclassmate.portfolio",
  "appName": "XuXu Pro",
  "webDir": "out",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#2563EB"
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#2563EB"
    },
    "Notifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  },
  "android": {
    "buildOptions": {
      "releaseType": "APK"
    }
  }
}
